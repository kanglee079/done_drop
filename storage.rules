rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUser() {
      return request.auth.uid;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && currentUser() == ownerId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnderSize(maxBytes) {
      return request.resource.size < maxBytes;
    }

    // ── USER AVATARS ────────────────────────────────────────────────────────

    match /avatars/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId)
        && isImage()
        && isUnderSize(5 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }

    // ── MOMENT IMAGES ────────────────────────────────────────────────────────
    // Visibility enforcement is at Firestore level; storage only checks ownership.

    match /moments/{userId}/{momentId}/{fileName} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && isImage()
        && isUnderSize(10 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }

    // ── LEGACY: CIRCLE COVER PHOTOS (V1 — dormant, read-only) ───────────────

    match /circles/{circleId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
