rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ══════════════════════════════════════════════════════════════════
    // Helper functions
    // ══════════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUser() {
      return request.auth.uid;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && currentUser() == ownerId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnderSize(int maxBytes) {
      return request.resource.size < maxBytes;
    }

    // ══════════════════════════════════════════════════════════════════
    // USER AVATARS
    // ══════════════════════════════════════════════════════════════════
    match /avatars/{userId}/{fileName} {
      // Anyone authenticated can read (needed for displaying friend profiles)
      allow read: if isAuthenticated();
      // Only the owner can write their own avatar
      allow write: if isOwner(userId)
        && isImage()
        && isUnderSize(5 * 1024 * 1024); // 5MB
    }

    // ══════════════════════════════════════════════════════════════════
    // MOMENT IMAGES
    // ══════════════════════════════════════════════════════════════════
    match /moments/{userId}/{momentId}/{fileName} {
      // Only the owner can read/write their own moments
      // NOTE: Moment visibility is enforced at the Firestore /moments/{momentId} level.
      // Storage only checks ownership. Firestore rules enforce who can read the
      // moment metadata (which contains the storage path).
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && isImage()
        && isUnderSize(10 * 1024 * 1024); // 10MB
    }

    // ══════════════════════════════════════════════════════════════════
    // LEGACY: CIRCLE COVER PHOTOS (V1.5 — dormant)
    // ══════════════════════════════════════════════════════════════════
    match /circles/{circleId}/{fileName} {
      // Any authenticated user in the circle can read
      allow read: if isAuthenticated();
      // Only circle members can write cover photos
      // Note: circle membership check requires a Firestore lookup.
      // For simplicity, we allow the authenticated user to write.
      // Circle membership is enforced at Firestore level.
      allow write: if isAuthenticated()
        && isImage()
        && isUnderSize(5 * 1024 * 1024); // 5MB
    }
  }
}
