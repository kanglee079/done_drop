rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════
    // Helper functions
    // ══════════════════════════════════════════════════════════════════

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the current user's ID
    function currentUser() {
      return request.auth.uid;
    }

    // Check if user is the owner of a resource
    function isOwner(ownerId) {
      return isAuthenticated() && currentUser() == ownerId;
    }

    // Get a resource's data (for use in get() calls)
    function getResourceData(path) {
      return get(/databases/$(database)/documents/$(path)).data;
    }

    // Check if user is blocked by the owner
    function isNotBlockedBy(String ownerId) {
      return !(currentUser() in getResourceData('users/' + ownerId).blockedUserIds);
    }

    // Check if two users are friends (mutual friendship document exists)
    function areFriends(String userId1, String userId2) {
      return exists(/databases/$(database)/documents/friendships/$(userId1)_$(userId2))
          || exists(/databases/$(database)/documents/friendships/$(userId2)_$(userId1));
    }

    // ── Friend count helpers ───────────────────────────────────────────
    // Counts friendships where currentUser is involved.
    // Used to enforce maxFriendsFree = 5 cap for free users.

    function currentUserFriendships() {
      return getDatabases(
        database
      ).documents.field(
        path: 'friendships',
        name: 'friendShipsCollection'
      ).where(
        filters: [
          filter(
            path: 'userId1',
            op_string: 'EQUAL',
            value: currentUser()
          )
        ]
      );
    }

    // V1 free plan: max 5 accepted friends per user.
    function isBelowFriendCap() {
      // Check both possible friendship ID formats (userId1 < userId2)
      // Approximate: count friendships where currentUser == userId1 or userId2
      // Firestore rules don't support aggregate counts easily, so we use
      // a conservative approach: check individual docs up to 5.
      // This is a soft cap — client enforces the primary check.
      // TODO (Sprint 3): Deploy callable function for hard cap enforcement.
      return true;
    }

    // ══════════════════════════════════════════════════════════════════
    // USERS
    // ══════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        currentUser() == userId
        || areFriends(currentUser(), userId)
      );

      allow create: if isOwner(userId)
        && request.resource.data.id == currentUser();

      allow update: if isOwner(userId)
        && request.resource.data.id == userId;

      allow delete: if false;

      match /blockedUsers/{blockedId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }
    }

    // ══════════════════════════════════════════════════════════════════
    // FRIENDSHIPS
    // ══════════════════════════════════════════════════════════════════
    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (
        currentUser() in [request.resource.data.userId1, request.resource.data.userId2]
        || currentUser() in [resource.data.userId1, resource.data.userId2]
      );

      allow create: if isAuthenticated()
        && currentUser() in [request.resource.data.userId1, request.resource.data.userId2];

      allow update: if false;

      allow delete: if isAuthenticated() && (
        currentUser() == resource.data.userId1
        || currentUser() == resource.data.userId2
      );
    }

    // ══════════════════════════════════════════════════════════════════
    // FRIEND REQUESTS
    // ══════════════════════════════════════════════════════════════════
    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );

      // Create: user sends request to someone else
      allow create: if isAuthenticated()
        && request.resource.data.senderId == currentUser()
        && request.resource.data.receiverId != currentUser();

      // Update (accept/decline/cancel):
      // - Sender can cancel their own request
      // - Receiver can accept or decline
      // - Accepting a request creates a friendship; declining does not
      allow update: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );

      allow delete: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );
    }

    // ══════════════════════════════════════════════════════════════════
    // ACTIVITIES
    // ══════════════════════════════════════════════════════════════════
    match /activities/{activityId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ══════════════════════════════════════════════════════════════════
    // ACTIVITY INSTANCES
    // ══════════════════════════════════════════════════════════════════
    match /activity_instances/{instanceId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ══════════════════════════════════════════════════════════════════
    // COMPLETION LOGS
    // ══════════════════════════════════════════════════════════════════
    match /completion_logs/{logId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if false; // Completion logs are immutable
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ══════════════════════════════════════════════════════════════════
    // MOMENTS
    // ══════════════════════════════════════════════════════════════════
    match /moments/{momentId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == currentUser()
        || (
          resource.data.visibility == 'all_friends'
          && areFriends(resource.data.ownerId, currentUser())
          && isNotBlockedBy(resource.data.ownerId)
        )
        || (
          resource.data.visibility == 'selected_friends'
          && currentUser() in resource.data.selectedFriendIds
          && isNotBlockedBy(resource.data.ownerId)
        )
      );

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();

      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();

      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();

      match /reactions/{reactionId} {
        allow read: if isAuthenticated() && (
          resource.data.userId == currentUser()
          || getResourceData('moments/' + resource.data.momentId).ownerId == currentUser()
        );

        allow create: if isAuthenticated()
          && request.resource.data.userId == currentUser();

        allow update: if false;

        allow delete: if isAuthenticated()
          && resource.data.userId == currentUser();
      }
    }

    // ══════════════════════════════════════════════════════════════════
    // FEED DELIVERIES
    // ══════════════════════════════════════════════════════════════════
    match /feed_deliveries/{deliveryId} {
      allow read: if isAuthenticated()
        && resource.data.recipientId == currentUser();

      allow create: if isAuthenticated()
        && request.resource.data.recipientId == currentUser();

      allow update: if isAuthenticated()
        && resource.data.recipientId == currentUser();

      allow delete: if isAuthenticated()
        && resource.data.recipientId == currentUser();
    }

    // ══════════════════════════════════════════════════════════════════
    // WEEKLY RECAPS
    // ══════════════════════════════════════════════════════════════════
    match /weekly_recaps/{recapId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();
      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // REPORTS
    // ══════════════════════════════════════════════════════════════════
    match /reports/{reportId} {
      allow read: if false;
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == currentUser();
      allow update: if false;
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // LEGACY: CIRCLES (deprecated in V1 — kept for data migration)
    // ══════════════════════════════════════════════════════════════════
    match /circles/{circleId} {
      allow read: if isAuthenticated()
        && currentUser() in resource.data.memberIds;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser()
        && currentUser() in request.resource.data.memberIds;
      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();
    }

    match /circle_memberships/{membershipId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == currentUser()
        || currentUser() in getResourceData('circles/' + resource.data.circleId).memberIds
      );
      allow create: if isAuthenticated()
        && request.resource.data.userId == currentUser();
      allow update: if isAuthenticated() && (
        resource.data.userId == currentUser()
        || currentUser() in getResourceData('circles/' + resource.data.circleId).memberIds
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == currentUser()
        || currentUser() == getResourceData('circles/' + resource.data.circleId).ownerId
      );
    }

    match /invites/{inviteId} {
      allow read: if isAuthenticated()
        && currentUser() in getResourceData('circles/' + resource.data.circleId).memberIds;
      allow create: if isAuthenticated()
        && currentUser() == request.resource.data.createdBy
        && currentUser() in getResourceData('circles/' + request.resource.data.circleId).memberIds;
      allow update: if isAuthenticated()
        && currentUser() == resource.data.createdBy;
      allow delete: if isAuthenticated()
        && currentUser() == resource.data.createdBy;
    }

    // ══════════════════════════════════════════════════════════════════
    // LEGACY: TASK TEMPLATES (replaced by Activities in V1)
    // ══════════════════════════════════════════════════════════════════
    match /task_templates/{taskId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();
      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();
    }

    // ══════════════════════════════════════════════════════════════════
    // LEGACY: images collection (BASE64 in Firestore — DEPRECATED)
    // DEPRECATED: All new images use Firebase Storage + Firestore metadata.
    // These rules allow read/delete of existing base64 image data only.
    // ══════════════════════════════════════════════════════════════════
    match /images/{imageId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == currentUser()
        || (
          resource.data.circleId != null
          && currentUser() in getResourceData('circles/' + resource.data.circleId).memberIds
        )
      );
      allow create: if false; // No new base64 images allowed
      allow update: if false;
      allow delete: if isAuthenticated()
        && resource.data.userId == currentUser();
    }
  }
}
