rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUser() {
      return request.auth.uid;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && currentUser() == ownerId;
    }

    // Check if two users are friends by verifying either friendship document exists.
    // Friendship documents use sorted ID format: id1_id2 (id1 < id2 lexicographically).
    // The friendship doc ID is already the concatenation, so we pass it as a single param.
    function friendshipDocExists(friendshipId) {
      return exists(path('friendships/'+friendshipId));
    }

    function areFriends(userId1, userId2) {
      return friendshipDocExists(userId1+'_'+userId2)
          || friendshipDocExists(userId2+'_'+userId1);
    }

    // Soft cap: Firestore rules don't support aggregate counts.
    // Client enforces the primary check; this returns true as fallback.
    function isBelowFriendCap() {
      return true;
    }

    // ── USERS ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        currentUser() == userId
        || areFriends(currentUser(), userId)
      );

      allow create: if isOwner(userId)
        && request.resource.data.id == currentUser();

      allow update: if isOwner(userId)
        && request.resource.data.id == userId;

      allow delete: if false;

      match /blockedUsers/{blockedId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }
    }

    // ── FRIENDSHIPS ─────────────────────────────────────────────────────────

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (
        currentUser() == resource.data.userId1
        || currentUser() == resource.data.userId2
      );

      allow create: if isAuthenticated()
        && currentUser() in [request.resource.data.userId1, request.resource.data.userId2];

      allow update: if false;

      allow delete: if isAuthenticated() && (
        currentUser() == resource.data.userId1
        || currentUser() == resource.data.userId2
      );
    }

    // ── FRIEND REQUESTS ─────────────────────────────────────────────────────

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );

      allow create: if isAuthenticated()
        && request.resource.data.senderId == currentUser()
        && request.resource.data.receiverId != currentUser();

      allow update: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );

      allow delete: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );
    }

    // ── ACTIVITIES ──────────────────────────────────────────────────────────

    match /activities/{activityId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ── ACTIVITY INSTANCES ──────────────────────────────────────────────────

    match /activity_instances/{instanceId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ── COMPLETION LOGS ─────────────────────────────────────────────────────

    match /completion_logs/{logId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      // Immutable after creation — only momentId can be linked post-completion.
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['momentId']);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ── MOMENTS ─────────────────────────────────────────────────────────────

    match /moments/{momentId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == currentUser()
        || (
          resource.data.visibility == 'all_friends'
          && areFriends(resource.data.ownerId, currentUser())
        )
        || (
          resource.data.visibility == 'selected_friends'
          && currentUser() in resource.data.selectedFriendIds
        )
      );

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();

      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();

      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();

      match /reactions/{reactionId} {
        // Anyone authenticated can read reactions (no sensitive data).
        allow read: if isAuthenticated();

        allow create: if isAuthenticated()
          && request.resource.data.userId == currentUser();

        allow update: if false;

        allow delete: if isAuthenticated()
          && resource.data.userId == currentUser();
      }
    }

    // ── FEED DELIVERIES ─────────────────────────────────────────────────────

    match /feed_deliveries/{deliveryId} {
      allow read: if isAuthenticated()
        && resource.data.recipientId == currentUser();

      // The moment OWNER creates deliveries for friends; ownerId must match.
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();

      allow update: if isAuthenticated()
        && resource.data.recipientId == currentUser();

      allow delete: if isAuthenticated()
        && resource.data.recipientId == currentUser();
    }

    // ── WEEKLY RECAPS ───────────────────────────────────────────────────────

    match /weekly_recaps/{recapId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();
      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow delete: if false;
    }

    // ── REPORTS ─────────────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if false;
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == currentUser();
      allow update: if false;
      allow delete: if false;
    }

    // ── LEGACY: CIRCLES (V1 — read-only) ───────────────────────────────────

    match /circles/{circleId} {
      allow read: if isAuthenticated()
        && currentUser() in resource.data.memberIds;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /circle_memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── LEGACY: TASK TEMPLATES (replaced by Activities) ─────────────────────

    match /task_templates/{taskId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── LEGACY: base64 images (DEPRECATED — no new writes) ─────────────────

    match /images/{imageId} {
      allow read: if isAuthenticated() && resource.data.userId == currentUser();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
