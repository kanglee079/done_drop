rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUser() {
      return request.auth.uid;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && currentUser() == ownerId;
    }

    // Check if two users are friends by verifying either friendship document exists.
    // Friendship documents use sorted ID format: id1_id2 (id1 < id2 lexicographically).
    // The friendship doc ID is already the concatenation, so we pass it as a single param.
    function friendshipDocExists(friendshipId) {
      return exists(/databases/$(database)/documents/friendships/$(friendshipId));
    }

    function areFriends(userId1, userId2) {
      return friendshipDocExists(userId1+'_'+userId2)
          || friendshipDocExists(userId2+'_'+userId1);
    }

    function isMomentOwner(momentId) {
      return exists(/databases/$(database)/documents/moments/$(momentId))
        && get(/databases/$(database)/documents/moments/$(momentId)).data.ownerId == currentUser();
    }

    // Soft cap: Firestore rules don't support aggregate counts.
    // Client enforces the primary check; this returns true as fallback.
    function isBelowFriendCap() {
      return true;
    }

    function isValidPublicDirectoryData(data, userId) {
      return data.id == userId
        && data.keys().hasOnly([
          'id',
          'displayName',
          'username',
          'userCode',
          'avatarUrl',
          'bio',
          'createdAt',
          'premiumStatus'
        ]);
    }

    function isValidLookupData(data, userId, fieldName, fieldValue) {
      return data.userId == userId
        && data[fieldName] == fieldValue
        && data.keys().hasOnly(['userId', fieldName]);
    }

    // ── USERS ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        currentUser() == userId
        || areFriends(currentUser(), userId)
      );

      // Allow create for the user's own document with flexible validation
      // This is more permissive to handle initial setup race conditions
      allow create: if isOwner(userId)
        && (
          request.resource.data.id == currentUser()
          || request.resource.data.id == null
        );

      allow update: if isOwner(userId)
        && (
          request.resource.data.id == userId
          || request.resource.data.id == null
        );

      allow delete: if isOwner(userId);

      match /blockedUsers/{blockedId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }
    }

    match /user_directory/{userId} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create: if isOwner(userId)
        && isValidPublicDirectoryData(request.resource.data, userId);
      allow update: if isOwner(userId)
        && isValidPublicDirectoryData(request.resource.data, userId);
      allow delete: if isOwner(userId);
    }

    match /user_code_lookup/{code} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create: if isAuthenticated()
        && isValidLookupData(request.resource.data, currentUser(), 'code', code);
      allow update: if isAuthenticated()
        && resource.data.userId == currentUser()
        && isValidLookupData(request.resource.data, currentUser(), 'code', code);
      allow delete: if isAuthenticated() && resource.data.userId == currentUser();
    }

    match /user_username_lookup/{username} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create: if isAuthenticated()
        && isValidLookupData(
          request.resource.data,
          currentUser(),
          'username',
          username
        );
      allow update: if isAuthenticated()
        && resource.data.userId == currentUser()
        && isValidLookupData(
          request.resource.data,
          currentUser(),
          'username',
          username
        );
      allow delete: if isAuthenticated() && resource.data.userId == currentUser();
    }

    match /user_email_lookup/{email} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create: if isAuthenticated()
        && isValidLookupData(request.resource.data, currentUser(), 'email', email);
      allow update: if isAuthenticated()
        && resource.data.userId == currentUser()
        && isValidLookupData(request.resource.data, currentUser(), 'email', email);
      allow delete: if isAuthenticated() && resource.data.userId == currentUser();
    }

    // ── FRIENDSHIPS ─────────────────────────────────────────────────────────

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (
        currentUser() == resource.data.userId1
        || currentUser() == resource.data.userId2
      );

      allow create: if isAuthenticated()
        && currentUser() in [request.resource.data.userId1, request.resource.data.userId2];

      allow update: if false;

      allow delete: if isAuthenticated() && (
        currentUser() == resource.data.userId1
        || currentUser() == resource.data.userId2
      );
    }

    // ── FRIEND REQUESTS ─────────────────────────────────────────────────────

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );

      allow create: if isAuthenticated()
        && request.resource.data.senderId == currentUser()
        && request.resource.data.receiverId != currentUser();

      allow update: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );

      allow delete: if isAuthenticated() && (
        resource.data.senderId == currentUser()
        || resource.data.receiverId == currentUser()
      );
    }

    // ── REACTIONS (top-level collection used by the app) ────────────────────

    match /reactions/{reactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == currentUser();
      allow update: if false;
      allow delete: if isAuthenticated() && (
        resource.data.userId == currentUser()
        || isMomentOwner(resource.data.momentId)
      );
    }

    // ── ACTIVITIES ──────────────────────────────────────────────────────────

    match /activities/{activityId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ── ACTIVITY INSTANCES ──────────────────────────────────────────────────

    match /activity_instances/{instanceId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ── COMPLETION LOGS ─────────────────────────────────────────────────────

    match /completion_logs/{logId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
      // Immutable after creation — only momentId can be linked post-completion.
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['momentId']);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ── MOMENTS ─────────────────────────────────────────────────────────────

    match /moments/{momentId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == currentUser()
        || (
          resource.data.visibility == 'all_friends'
          && areFriends(resource.data.ownerId, currentUser())
        )
        || (
          resource.data.visibility == 'selected_friends'
          && currentUser() in resource.data.selectedFriendIds
        )
      );

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();

      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();

      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();

      match /reactions/{reactionId} {
        // Anyone authenticated can read reactions (no sensitive data).
        allow read: if isAuthenticated();

        allow create: if isAuthenticated()
          && request.resource.data.userId == currentUser();

        allow update: if false;

        allow delete: if isAuthenticated()
          && resource.data.userId == currentUser();
      }
    }

    // ── FEED DELIVERIES ─────────────────────────────────────────────────────

    match /feed_deliveries/{deliveryId} {
      allow read: if isAuthenticated()
        && resource.data.recipientId == currentUser();

      // The moment OWNER creates deliveries for friends; ownerId must match.
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();

      allow update: if isAuthenticated()
        && resource.data.recipientId == currentUser();

      allow delete: if isAuthenticated() && (
        resource.data.recipientId == currentUser()
        || resource.data.ownerId == currentUser()
      );
    }

    // ── CHATS ───────────────────────────────────────────────────────────────

    match /chats/{threadId} {
      allow read: if isAuthenticated()
        && currentUser() in resource.data.participantIds;

      allow create: if isAuthenticated()
        && request.resource.data.id == threadId
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && currentUser() in request.resource.data.participantIds
        && areFriends(
          request.resource.data.participantIds[0],
          request.resource.data.participantIds[1]
        );

      allow update: if isAuthenticated()
        && currentUser() in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds
        && areFriends(resource.data.participantIds[0], resource.data.participantIds[1]);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && exists(/databases/$(database)/documents/chats/$(threadId))
          && currentUser() in get(/databases/$(database)/documents/chats/$(threadId)).data.participantIds;

        allow create: if isAuthenticated()
          && exists(/databases/$(database)/documents/chats/$(threadId))
          && currentUser() in get(/databases/$(database)/documents/chats/$(threadId)).data.participantIds
          && request.resource.data.senderId == currentUser()
          && request.resource.data.threadId == threadId;

        allow update: if false;
        allow delete: if false;
      }
    }

    // ── WEEKLY RECAPS ───────────────────────────────────────────────────────

    match /weekly_recaps/{recapId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == currentUser();
      allow update: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();
    }

    // ── REPORTS ─────────────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if false;
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == currentUser();
      allow update: if false;
      allow delete: if false;
    }

    // ── LEGACY: CIRCLES (V1 — read-only) ───────────────────────────────────

    match /circles/{circleId} {
      allow read: if isAuthenticated()
        && currentUser() in resource.data.memberIds;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /circle_memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── LEGACY: TASK TEMPLATES (replaced by Activities) ─────────────────────

    match /task_templates/{taskId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == currentUser();
      allow create: if false;
      allow update: if false;
      allow delete: if isAuthenticated()
        && resource.data.ownerId == currentUser();
    }

    // ── LEGACY: base64 images (DEPRECATED — no new writes) ─────────────────

    match /images/{imageId} {
      allow read: if isAuthenticated() && resource.data.userId == currentUser();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
