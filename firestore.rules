rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId
        && request.resource.data.id == request.auth.uid;
      allow update: if request.auth.uid == userId
        && request.resource.data.id == userId;
      allow delete: if false;
    }

    // ── Task Templates ──────────────────────────────────────────────────
    match /task_templates/{taskId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth.uid == resource.data.ownerId
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    // ── Circles ─────────────────────────────────────────────────────────
    match /circles/{circleId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.memberIds;
      // FIX: Prevent owner from arbitrarily modifying memberIds in a way that grants access
      allow update: if request.auth.uid == resource.data.ownerId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['memberIds'])
            || request.resource.data.memberIds.hasAll(resource.data.memberIds));
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    // ── Circle Memberships ───────────────────────────────────────────────
    match /circle_memberships/{membershipId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.memberIds);
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth.uid == resource.data.userId
        || request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.memberIds;
      allow delete: if request.auth.uid == resource.data.userId
        || request.auth.uid == get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.ownerId;
    }

    // ── Invites ─────────────────────────────────────────────────────────
    // FIX: Only circle members can read invites (was: any authenticated user).
    // FIX: Validate that invite's circleId exists and user is a member.
    match /invites/{inviteId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.memberIds;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy
        && request.auth.uid in get(/databases/$(database)/documents/circles/$(request.resource.data.circleId)).data.memberIds;
      allow update: if request.auth.uid == request.resource.data.createdBy;
      allow delete: if request.auth.uid == request.resource.data.createdBy;
    }

    // ── Moments ──────────────────────────────────────────────────────────
    match /moments/{momentId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
          || (resource.data.visibility == 'circle'
            && resource.data.circleId != null
            && request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.memberIds
            && !(request.auth.uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blockedUserIds)));
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth.uid == resource.data.ownerId;
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    // ── Friend Requests ─────────────────────────────────────────────────
    match /friend_requests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
      allow create: if request.auth.uid == request.resource.data.senderId;
      allow update: if request.auth != null
        && (resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
    }

    // ── Reactions ────────────────────────────────────────────────────────
    // FIX: Only the reaction author or the moment owner can read reactions
    // (was: any authenticated user could enumerate all reactions).
    match /reactions/{reactionId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || request.auth.uid == get(/databases/$(database)/documents/moments/$(resource.data.momentId)).data.ownerId);
      allow create: if request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ── Weekly Recaps ───────────────────────────────────────────────────
    match /weekly_recaps/{recapId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth.uid == resource.data.ownerId;
      allow delete: if false;
    }

    // ── Images (base64 stored in Firestore) ───────────────────────────────
    match /images/{imageId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.memberIds);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ── Reports ─────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth.uid == request.resource.data.reporterId;
      allow update: if false;
      allow delete: if false;
    }
  }
}
